# ─────────────────────────────────────────────────────────────
# Variables de entorno — Ofipapel App
# ─────────────────────────────────────────────────────────────
# Copia este fichero como .env.local para desarrollo local.
# NUNCA commitees .env.local ni ningún fichero con valores reales.
# ─────────────────────────────────────────────────────────────

# Claude / Anthropic API
# ─────────────────────────────────────────────────────────────
# Solo necesaria en Netlify (build/server-side functions).
# En el navegador, el usuario introduce su clave manualmente
# y se guarda en localStorage bajo 'op_claude_key'.
# NUNCA incluir en código cliente.
ANTHROPIC_API_KEY=sk-ant-...

# Node (ya configurado en netlify.toml, no suele hacer falta aquí)
# NODE_VERSION=20

# ─────────────────────────────────────────────────────────────
# Supabase (si se migra a backend)
# ─────────────────────────────────────────────────────────────
# La anon key está actualmente hardcodeada en Index.html (intencional,
# protegida por RLS). Si se externaliza en el futuro, usar estas vars.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
